//----------------------------------------------
// general shizzle

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

user - 12
friend ( user 2/ friendship connection is 1)

//----------------------------------------------
// user management

model User {
	id				Int			@id @default(autoincrement())
	username		String		@unique
	password		String
	email			String		@unique
	avatar			String		@default("img_avatar.png")
	status			Boolean		@default(false) 
	wins			Int
	lossess			Int	
	friends			User[]
}

//fRequests	could be handled in the relationship status area of friend
enum RelationshipStatus {
  ACCEPTED
  PENDING
  REJECTED
}



//----------------------------------------------
// game + matches

// make as model that is included in user + game similar to friends
	//matches - dates + relevant info - where and how do this?

model Game {
	id	Int		@id @default(autoincrement())
	username String     @unique
	avatar String
	status Boolean     @default(false)
	positionX Int
	positionY Int
	elo_rating Int
}
